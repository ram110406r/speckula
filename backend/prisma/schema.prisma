// Prisma schema for the AI service layer.
// Stores AI outputs, reasoning traces, and caches.
// The source of truth for user data remains in Firestore.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// =========================
// AI CACHE & OUTPUTS
// =========================

/// AI-generated insights from Groq. Referenced by the frontend via Firestore.
model AIInsight {
  id              String    @id @default(uuid())
  projectId       String
  noteId          String
  userId          String
  content         String
  source          String    @default("groq")
  confidenceScore Float     @default(0.7)
  modelUsed       String
  tokensUsed      Int       @default(0)
  generatedAt     DateTime  @default(now())
  expiresAt       DateTime?

  @@index([projectId])
  @@index([userId])
  @@index([noteId])
  @@index([generatedAt])
}

/// AI-generated PRDs from Groq. Referenced by the frontend via Firestore.
model AIPRD {
  id          String   @id @default(uuid())
  projectId   String
  userId      String
  title       String
  content     String
  version     Int      @default(1)
  modelUsed   String
  tokensUsed  Int      @default(0)
  generatedAt DateTime @default(now())

  @@index([projectId])
  @@index([userId])
}

/// Reasoning traces for decisions (why Groq gave this confidence score).
model DecisionReasoning {
  id                  String   @id @default(uuid())
  decisionId          String
  projectId           String
  userId              String
  prompt              String
  reasoning           String
  confidenceScore     Float
  confidenceReasoning String
  modelUsed           String
  tokensUsed          Int      @default(0)
  generatedAt         DateTime @default(now())

  @@index([decisionId])
  @@index([projectId])
  @@index([userId])
}

/// Pattern analysis from real-time note updates: repeated keywords, weak signals, suggestions.
model PatternAnalysis {
  id         String    @id @default(uuid())
  projectId  String
  noteId     String
  userId     String
  patterns   String
  modelUsed  String
  tokensUsed Int       @default(0)
  analyzedAt DateTime  @default(now())
  expiresAt  DateTime?

  @@index([projectId])
  @@index([noteId])
  @@index([analyzedAt])
}

/// Prompt history and results for cost tracking and deduplication.
model PromptLog {
  id           String   @id @default(uuid())
  userId       String
  projectId    String
  promptHash   String
  prompt       String
  modelUsed    String
  inputTokens  Int
  outputTokens Int
  totalTokens  Int
  executionMs  Int
  cost         Float
  cachedResult Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([projectId])
  @@index([promptHash])
  @@index([createdAt])
}

/// TTL-based cache of prompt results to avoid duplicate Groq calls.
model PromptCache {
  id             String   @id @default(uuid())
  promptHash     String   @unique
  result         String
  modelUsed      String
  expiresAt      DateTime
  hitCount       Int      @default(0)
  createdAt      DateTime @default(now())
  lastAccessedAt DateTime @updatedAt

  @@index([expiresAt])
}

/// Task suggestions from Groq. Referenced by the frontend via Firestore.
model AISuggestedTask {
  id              String   @id @default(uuid())
  projectId       String
  prdId           String?
  userId          String
  title           String
  description     String?
  priority        String   @default("medium")
  reasoning       String
  confidenceScore Float    @default(0.7)
  modelUsed       String
  tokensUsed      Int      @default(0)
  generatedAt     DateTime @default(now())
  dismissed       Boolean  @default(false)

  @@index([projectId])
  @@index([prdId])
  @@index([userId])
}

/// Daily API usage aggregated per user for cost/quota monitoring.
model APIUsage {
  id            String   @id @default(uuid())
  userId        String
  date          DateTime @default(now())
  totalRequests Int      @default(0)
  totalTokens   Int      @default(0)
  totalCost     Float    @default(0.0)
  modelMix      String

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}
