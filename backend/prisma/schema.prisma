// Prisma schema for the AI service layer.
// Stores AI outputs, reasoning traces, and caches.
// The source of truth for user data remains in Firestore.

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// =========================
// AI CACHE & OUTPUTS
// =========================

/// AI-generated insights from Groq. Referenced by the frontend via Firestore.
model AIInsight {
  id              String    @id @default(uuid())
  projectId       String
  noteId          String
  userId          String
  content         String
  source          String    @default("groq")
  confidenceScore Float     @default(0.7)
  modelUsed       String
  tokensUsed      Int       @default(0)
  generatedAt     DateTime  @default(now())
  expiresAt       DateTime?

  @@index([projectId])
  @@index([userId])
  @@index([noteId])
  @@index([generatedAt])
}

/// AI-generated PRDs from Groq. Referenced by the frontend via Firestore.
model AIPRD {
  id          String   @id @default(uuid())
  projectId   String
  userId      String
  title       String
  content     String
  version     Int      @default(1)
  modelUsed   String
  tokensUsed  Int      @default(0)
  generatedAt DateTime @default(now())

  @@index([projectId])
  @@index([userId])
}

/// Reasoning traces for decisions (why Groq gave this confidence score).
/// One row per decision; upserted on re-score.
model DecisionReasoning {
  id                  String   @id @default(uuid())
  decisionId          String   @unique
  projectId           String
  userId              String
  prompt              String
  reasoning           String
  confidenceScore     Float
  confidenceReasoning String
  modelUsed           String
  tokensUsed          Int      @default(0)
  generatedAt         DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([projectId])
  @@index([userId])
  @@index([userId, generatedAt])
}

/// Pattern analysis from real-time note updates: repeated keywords, weak signals, suggestions.
model PatternAnalysis {
  id         String    @id @default(uuid())
  projectId  String
  noteId     String
  userId     String
  patterns   String
  modelUsed  String
  tokensUsed Int       @default(0)
  analyzedAt DateTime  @default(now())
  expiresAt  DateTime?

  @@index([projectId])
  @@index([noteId])
  @@index([analyzedAt])
}

/// Prompt history and results for cost tracking and deduplication.
/// Has a retention sweeper; see services/retention.ts.
model PromptLog {
  id            String   @id @default(uuid())
  userId        String
  projectId     String
  promptHash    String
  prompt        String
  modelUsed     String
  inputTokens   Int
  outputTokens  Int
  totalTokens   Int
  executionMs   Int
  cost          Float
  cachedResult  Boolean  @default(false)
  // v2.3 prompt registry correlation. Forwarded from the frontend in `_meta`.
  // Both nullable for back-compat with legacy log rows.
  promptId      String?
  promptVersion String?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([projectId])
  @@index([promptHash])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([promptId])
}

/// TTL-based cache of prompt results to avoid duplicate Groq calls.
model PromptCache {
  id             String   @id @default(uuid())
  promptHash     String   @unique
  result         String
  modelUsed      String
  expiresAt      DateTime
  hitCount       Int      @default(0)
  createdAt      DateTime @default(now())
  lastAccessedAt DateTime @updatedAt

  @@index([expiresAt])
}

/// Task suggestions from Groq. Referenced by the frontend via Firestore.
model AISuggestedTask {
  id              String   @id @default(uuid())
  projectId       String
  prdId           String?
  userId          String
  title           String
  description     String?
  priority        String   @default("medium")
  reasoning       String
  confidenceScore Float    @default(0.7)
  modelUsed       String
  tokensUsed      Int      @default(0)
  generatedAt     DateTime @default(now())
  dismissed       Boolean  @default(false)

  @@index([projectId])
  @@index([prdId])
  @@index([userId])
}

// =========================
// EXTENSION TRACKING
// =========================

/// Last-known state per user's extension installation.
/// Upserted on every heartbeat — one row per (userId, browserFingerprint).
model ExtensionSession {
  id               String   @id @default(uuid())
  userId           String
  extensionVersion String
  browserType      String
  workspaceId      String?
  lastSeenAt       DateTime @default(now())
  metadata         String?  // JSON: platform, os, etc.
  createdAt        DateTime @default(now())

  @@unique([userId, browserType])
  @@index([userId])
  @@index([lastSeenAt])
}

/// Raw heartbeat log — kept for 7 days, swept by retention sweeper.
model ExtensionHeartbeat {
  id               String   @id @default(uuid())
  userId           String
  extensionVersion String
  browserType      String
  workspaceId      String?
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// =========================
// JOB QUEUE
// =========================

/// Persistent job record for extension page analysis.
/// Mirrors the BullMQ job state so the frontend can poll progress.
model AnalysisJob {
  id           String    @id @default(uuid())
  userId       String
  projectId    String?
  workspaceId  String?
  bullJobId    String?   // BullMQ job.id (same as our id by default)
  status       String    @default("queued")
  // queued | extracting | classifying | generating_insights | embedding | saving | completed | failed
  progress     Int       @default(0)    // 0–100
  pageType     String?
  sourceUrl    String?
  inputContent String?   // stored for re-processing; cleared after embedding
  result       String?   // JSON: structured analysis output
  error        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  completedAt  DateTime?

  @@index([userId])
  @@index([workspaceId])
  @@index([status])
  @@index([createdAt])
}

// =========================
// PRODUCT BRAIN
// =========================

/// Persistent intelligence entry — the core of the startup memory graph.
model ProductBrainEntry {
  id           String   @id @default(uuid())
  userId       String
  workspaceId  String?
  entryType    String
  // competitor_insight | market_signal | pm_insight | pricing_observation
  // | onboarding_pattern | feature_comparison | strategic_decision | ux_friction
  title        String
  content      String
  metadata     String?  // JSON: arbitrary structured context
  sourceUrl    String?
  sourceJobId  String?  // AnalysisJob.id that generated this entry
  confidence   Float    @default(0.7)
  tags         String?  // JSON: string[]
  // Vector embedding stored in Postgres via raw SQL (pgvector).
  // Prisma cannot manage vector columns directly — added via migration.
  embeddingId     String?  @unique  // FK to SemanticEmbedding.id
  // decisionId enables O(1) indexed confidence updates in the learning loop
  // instead of a full table scan + JSON parse on every outcome analysis.
  decisionId      String?
  // pending | done | failed — lets background jobs retry silent embedding failures.
  embeddingStatus String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([workspaceId])
  @@index([entryType])
  @@index([createdAt])
  @@index([userId, decisionId])
}

/// pgvector embedding store — one row per ProductBrainEntry with an embedding.
/// The `embedding` column is added via raw SQL migration (see prisma/migrations).
model SemanticEmbedding {
  id        String   @id @default(uuid())
  entryId   String   @unique
  model     String   // e.g. "text-embedding-3-small"
  dims      Int      // embedding dimensions
  // embedding vector(1536) — managed by pgvector, not by Prisma ORM.
  // Use db.$queryRaw for similarity queries.
  createdAt DateTime @default(now())

  @@index([entryId])
}

/// Competitor intelligence — structured output from competitor page analysis.
model CompetitorInsight {
  id             String   @id @default(uuid())
  userId         String
  workspaceId    String?
  domain         String
  competitorName String?
  insightType    String
  // pricing | positioning | onboarding | ux | gtm | monetization | features | icp
  title          String
  content        String
  evidence       String?  // JSON: string[] — specific quotes / observations
  sourceUrl      String?
  confidence     Float    @default(0.7)
  sourceJobId    String?
  capturedAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([domain])
  @@index([insightType])
  @@index([capturedAt])
}

/// Market signal — trend, competitor move, or customer feedback worth tracking.
model MarketSignal {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String?
  signalType  String
  // trend | competitor_move | market_shift | customer_feedback | pricing_change | feature_launch
  title       String
  content     String
  sourceUrl   String?
  strength    Float    @default(0.5)  // 0–1
  tags        String?  // JSON: string[]
  sourceJobId String?
  detectedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([signalType])
  @@index([detectedAt])
}

// =========================
// NOTIFICATIONS
// =========================

/// In-app notification — delivered via WebSocket on creation, persisted for inbox.
model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  // analysis_completed | competitor_updated | pricing_changed | market_signal
  // | extension_disconnected | auth_expired | job_failed
  title     String
  body      String
  metadata  String?   // JSON: link, jobId, etc.
  read      Boolean   @default(false)
  createdAt DateTime  @default(now())
  readAt    DateTime?

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

// =========================
// OBSERVABILITY
// =========================

/// Audit log — records user-initiated actions for compliance and debugging.
model ActivityLog {
  id           String   @id @default(uuid())
  userId       String
  action       String   // e.g. "job.enqueue", "account.delete", "export.download"
  resourceType String?
  resourceId   String?
  metadata     String?  // JSON
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

/// Live WebSocket connection registry — rows are inserted on connect, deleted
/// on disconnect. Stale rows (lastPingAt older than 2 min) cleaned by a sweeper.
model WebSocketConnection {
  id           String   @id @default(uuid())
  userId       String
  workspaceId  String?
  connectionId String   @unique
  metadata     String?  // JSON: browser, version, etc.
  connectedAt  DateTime @default(now())
  lastPingAt   DateTime @default(now())

  @@index([userId])
  @@index([lastPingAt])
}

/// Daily API usage aggregated per user for cost/quota monitoring.
model APIUsage {
  id            String   @id @default(uuid())
  userId        String
  date          DateTime @default(now())
  totalRequests Int      @default(0)
  totalTokens   Int      @default(0)
  totalCost     Float    @default(0.0)
  modelMix      String

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

// =========================
// WORKSPACE ISOLATION
// =========================

/// Workspace — shared context for a team. All intelligence is scoped to a workspace.
model Workspace {
  id          String   @id @default(uuid())
  ownerId     String
  name        String
  slug        String   @unique
  description String?
  metadata    String?  // JSON: plan, logo, settings

  // Workspace profile fields (startup intelligence context)
  logoUrl        String?
  startupStage   String?
  industry       String?
  productCategory String?
  businessModel  String?
  icp            String?
  aiStrategy     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([ownerId])
  @@index([slug])
}

/// Workspace membership — roles: owner | editor | viewer.
model WorkspaceMember {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String
  role        String   @default("editor")  // owner | editor | viewer
  invitedBy   String?
  joinedAt    DateTime @default(now())

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

/// Workspace activity feed — realtime event stream persisted for dashboards.
model WorkspaceActivity {
  id          String   @id @default(uuid())
  workspaceId String
  actorId     String
  eventType   String
  title       String
  description String?
  entityType  String?
  entityId    String?
  metadata    String?  // JSON
  createdAt   DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@index([workspaceId, eventType])
  @@index([actorId, createdAt])
}

/// Workspace derived metrics — stored rollups for realtime cards.
model WorkspaceMetrics {
  id              String   @id @default(uuid())
  workspaceId     String   @unique
  totalSignals    Int      @default(0)
  totalDecisions  Int      @default(0)
  totalSpecs      Int      @default(0)
  totalTasks      Int      @default(0)
  totalExperiments Int     @default(0)
  aiConfidence    Float    @default(0)
  updatedAt       DateTime @updatedAt

  @@index([workspaceId])
}

/// Workspace context blob — injected into AI prompts for continuity.
model WorkspaceContext {
  id            String   @id @default(uuid())
  workspaceId   String   @unique
  competitors   String?  // JSON
  strategy      String?  // JSON
  goals         String?  // JSON
  constraints   String?  // JSON
  startupContext String? // JSON
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([workspaceId])
}

// =========================
// OUTCOME & LEARNING LOOP
// =========================

/// Expected vs actual outcome for a decision — triggers the learning loop.
model Outcome {
  id                String    @id @default(uuid())
  userId            String
  workspaceId       String?
  decisionId        String    // Firestore decision ID
  decisionTitle     String
  // Expected
  expectedMetric    String    // e.g. "Weekly active users"
  expectedValue     Float
  expectedTimeframe String    // e.g. "30 days"
  // Actual
  actualValue       Float?
  observedAt        DateTime?
  // Computed
  deviationPct      Float?    // ((actual - expected) / expected) * 100
  verdict           String?   // exceeded | met | missed | far_off
  // Status
  status            String    @default("pending")  // pending | recorded | analyzed
  confidenceDelta   Float?    // how much confidence changed after outcome
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  learningInsights  LearningInsight[]

  @@index([userId])
  @@index([decisionId])
  @@index([status])
  @@index([createdAt])
}

/// AI-generated insight explaining why a decision succeeded or failed.
model LearningInsight {
  id              String   @id @default(uuid())
  userId          String
  workspaceId     String?
  outcomeId       String
  decisionId      String
  insight         String   // main learning text
  rootCause       String?  // why it played out this way
  actionableNext  String?  // what to do differently next time
  confidenceShift Float    @default(0)   // +/- applied to decision confidence
  tags            String?  // JSON: string[]
  modelUsed       String
  tokensUsed      Int      @default(0)
  createdAt       DateTime @default(now())

  outcome         Outcome  @relation(fields: [outcomeId], references: [id])

  @@index([userId])
  @@index([outcomeId])
  @@index([decisionId])
  @@index([createdAt])
}

// =========================
// AUTONOMOUS AGENT RUNS
// =========================

/// A single Autonomous Mode session — tracks the full multi-step reasoning run.
model AgentRun {
  id            String    @id @default(uuid())
  userId        String
  workspaceId   String?
  idea          String    // the input idea/question
  depth         String    @default("standard")  // quick | standard | deep
  status        String    @default("running")
  // running | clarifying | researching | deciding | strategizing | generating_roadmap | completed | stopped | error
  currentStep   String?
  steps         String?   // JSON: AgentStep[] — full breadcrumb
  // Outputs
  clarifications  String?  // JSON: string[] — questions asked + answers
  decisions       String?  // JSON: top 3 candidate decisions
  strategy        String?  // JSON: strategic guidance
  roadmap         String?  // JSON: 3-phase roadmap
  verdict         String?  // PROCEED | VALIDATE_FIRST | DO_NOT_BUILD
  verdictReason   String?
  // Metadata
  modelUsed     String?
  tokensUsed    Int       @default(0)
  durationMs    Int?
  error         String?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?

  @@index([userId])
  @@index([status])
  @@index([startedAt])
}

// =========================
// ROADMAPS
// =========================

/// A roadmap item — quarter-scoped, AI-scored, linked to a decision.
model RoadmapItem {
  id            String   @id @default(uuid())
  userId        String
  workspaceId   String?
  title         String
  description   String?
  quarter       String   // e.g. "Q2 2026"
  status        String   @default("planned")  // planned | in_progress | completed | dropped
  priority      String   @default("medium")   // high | medium | low
  aiScore       Float?   // 0–1 alignment score from AI
  aiRationale   String?  // why this score
  decisionId    String?  // optional link to a Firestore decision
  dependsOn     String?  // JSON: string[] of RoadmapItem IDs
  tags          String?  // JSON: string[]
  progress      Int      @default(0)  // 0–100
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  @@index([userId])
  @@index([workspaceId])
  @@index([quarter])
  @@index([status])
}

// =========================
// EXPERIMENTS
// =========================

/// An A/B or multivariate experiment.
model Experiment {
  id             String              @id @default(uuid())
  userId         String
  workspaceId    String?
  title          String
  hypothesis     String
  targetMetric   String
  status         String              @default("planned")
  // planned | running | paused | completed | abandoned
  startedAt      DateTime?
  endedAt        DateTime?
  aiInsight      String?            // AI-generated interpretation of results
  tags           String?            // JSON: string[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?

  variants       ExperimentVariant[]

  @@index([userId])
  @@index([workspaceId])
  @@index([status])
  @@index([createdAt])
}

/// A variant within an experiment (including control).
model ExperimentVariant {
  id             String     @id @default(uuid())
  experimentId   String
  name           String     // e.g. "Control", "Variant A"
  isControl      Boolean    @default(false)
  impressions    Int        @default(0)
  conversions    Int        @default(0)
  // Stats (computed server-side)
  conversionRate Float?
  lift           Float?     // vs control, %
  pValue         Float?
  significant    Boolean?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  experiment     Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@index([experimentId])
}
