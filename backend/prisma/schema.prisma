// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ========================= 
// USER & AUTH
// =========================
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  passwordHash String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  ownedWorkspaces Workspace[]
  workspaceMembers WorkspaceMember[]
  notes Note[]
  insights Insight[]
  decisions Decision[]
  prdss PRD[]
  tasks Task[]

  @@index([email])
}

// ========================= 
// WORKSPACE / PROJECT
// =========================
model Workspace {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  members WorkspaceMember[]
  projects Project[]

  @@index([ownerId])
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String   @default("member") // owner, editor, viewer
  joinedAt    DateTime @default(now())

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model Project {
  id          String   @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  stage       String   @default("Discovery") // Discovery | Validation | Build | Scale
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  notes Note[]
  insights Insight[]
  decisions Decision[]
  prds PRD[]
  tasks Task[]
  integrations Integration[]

  @@index([workspaceId])
}

// ========================= 
// THINK (Notes + Insights)
// =========================
model Note {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String   // JSON or rich text
  lastInsightExtractionHash String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  insights Insight[] @relation("NoteInsights")

  @@index([projectId])
  @@index([userId])
}

model Insight {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  noteId    String?
  note      Note?    @relation("NoteInsights", fields: [noteId], references: [id], onDelete: SetNull)
  content   String
  source    String   @default("AI") // AI | USER
  confidenceScore Float @default(0.5)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([userId])
  @@index([noteId])
}

// ========================= 
// DECIDE (Decision Log + Tradeoffs)
// =========================
model Decision {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  description String
  status    String   @default("active") // active | completed | rejected
  confidenceScore Float @default(0.5)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tradeoffs Tradeoff[]
  outcomes DecisionOutcome[]

  @@index([projectId])
  @@index([userId])
}

model Tradeoff {
  id        String   @id @default(uuid())
  decisionId String
  decision  Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  optionA   String
  optionB   String
  reasoning String
  winner    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([decisionId])
}

model DecisionOutcome {
  id              String   @id @default(uuid())
  decisionId      String
  decision        Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  expectedOutcome String?
  actualOutcome   String?
  comparison      String?
  learningInsight String?
  confidenceAdjustment Float @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([decisionId])
}

// ========================= 
// BUILD (PRDs + Tasks)
// =========================
model PRD {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String   // Full PRD document
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tasks Task[]

  @@index([projectId])
  @@index([userId])
}

model Task {
  id                String   @id @default(uuid())
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prdId             String?
  prd               PRD?     @relation(fields: [prdId], references: [id], onDelete: SetNull)
  title             String
  description       String?
  status            String   @default("todo") // todo | in_progress | done
  priority          String   @default("medium") // low | medium | high | critical
  linkedDecisionId  String?
  dependsOnTaskId   String?
  isBlockedBy       Task?    @relation("TaskDependencies", fields: [dependsOnTaskId], references: [id], onDelete: SetNull)
  blocks            Task[]   @relation("TaskDependencies")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([projectId])
  @@index([userId])
  @@index([prdId])
  @@index([dependsOnTaskId])
}

// ========================= 
// SYSTEM (Integrations + Platform)
// =========================
model Integration {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String   // slack | jira | github | etc
  config    String   // JSON stored as string
  connectedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

// ========================= 
// TOKENS & SESSIONS
// =========================
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}
