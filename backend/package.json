{
  "name": "Speckula-ai-backend",
  "version": "1.0.0",
  "description": "Groq-powered AI service layer for Speckula with Firebase integration",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "retention:sweep": "tsx src/scripts/retentionSweeper.ts",
    "digest:send": "tsx src/scripts/weeklyDigest.ts",
    "worker": "tsx src/workers/analysisWorker.ts",
    "eval": "tsx src/eval/runEval.ts",
    "test": "vitest",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=false eslint --config .eslintrc.cjs --no-eslintrc --ext .ts src",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@sentry/node": "^8",
    "@extractus/article-extractor": "^8.0.20",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/websocket": "^11.0.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@types/node": "^20.10.6",
    "dotenv": "^16.3.1",
    "fastify": "^5.0.0",
    "firebase-admin": "^12.7.0",
    "groq-sdk": "^0.4.0",
    "pdf-parse": "^1.1.4",
    "pg": "^8.11.5",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "bullmq": "^5.0.0",
    "ioredis": "^5.3.2",
    "openai": "^4.0.0",
    "resend": "^4.0.0",
    "striptags": "^3.2.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/pdf-parse": "^1.1.5",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.56.0",
    "prisma": "^7.0.0",
    "tsx": "^4.7.0",
    "typescript": "5.5.4",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
