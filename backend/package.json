    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "@types/node": "^20.10.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "fastify": "^4.25.2",
    "fastify-cors": "^6.1.0",
    "fastify-jwt": "^7.5.0",
    "fastify-websocket": "^0.4.2",
    "groq-sdk": "^0.4.0",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "eslint": "^8.56.0",
    "prisma": "^5.8.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
