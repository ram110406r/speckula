rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isWorkspaceMember(workspaceId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.memberIds;
    }

    // ── Users ──────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update, delete: if isOwner(userId);

      // Buildcase documents — scoped per user
      match /documents/{docId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }

      // New Buildcase Sub-collections
      match /insights/{id} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
      match /decisions/{id} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
      match /prds/{id} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
      match /tasks/{id} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }

      // Connected Slack workspaces (metadata only — no tokens stored here).
      // User reads their own; backend (Admin SDK) writes via callback/channels routes.
      match /slackWorkspaces/{teamId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow write: if false;
      }
    }

    // ── Public Profiles ────────────────────────────────────
    match /publicProfiles/{userId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() && isOwner(userId);
    }

    // ── Public Cases ────────────────────────────────────────
    match /publicCases/{caseId} {
      allow read: if resource.data.visibility == "public" || (isAuthenticated() && isOwner(resource.data.userId));
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
      allow update, delete: if isAuthenticated() && isOwner(resource.data.userId);

      match /comments/{commentId} {
        allow read: if get(/databases/$(database)/documents/publicCases/$(caseId)).data.visibility == "public" || (isAuthenticated() && request.auth.uid == resource.data.userId);
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
      }
    }

    // ── Workspaces ──────────────────────────────────────────
    match /workspaces/{workspaceId} {
      allow read: if isWorkspaceMember(workspaceId);
      allow create: if isAuthenticated();
      allow update: if isWorkspaceMember(workspaceId);
      allow delete: if isWorkspaceMember(workspaceId) && resource.data.members[0].userId == request.auth.uid;
    }

    // ── Settings ───────────────────────────────────────────
    match /settings/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update, delete: if isOwner(userId);
    }

    // ── Slack Messages ──────────────────────────────────────
    // Backend (Admin SDK) writes; only the owning user can read their workspace's messages.
    match /slackMessages/{docId} {
      allow read: if isAuthenticated() && resource.data.ownerUserId == request.auth.uid;
      allow write: if false;
    }

    // ── Slack Installations ─────────────────────────────────
    // Encrypted bot tokens. Frontend never reads these.
    match /slackInstallations/{teamId} {
      allow read, write: if false;
    }
  }
}
